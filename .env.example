# Variables d'environnement — POC Avantages Sportifs

# --- Postgres (base RH + activités) ---
POSTGRES_USER=sportadmin
POSTGRES_PASSWORD=postgresadmin
POSTGRES_DB=sportdata

# --- MinIO (stockage Delta) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Airflow ---
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=airflowadmin
# Générer avec: python -c "import secrets; print(secrets.token_hex(16))"
AIRFLOW_SECRET_KEY=replace_with_random_hex_32
# Générer avec: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=replace_with_fernet_key

# --- Grafana ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafanaadmin

# --- API externes ---
GOOGLE_MAPS_API_KEY=MOCK
SLACK_WEBHOOK_URL=MOCK

# Adresse du bureau pour calcul des distances
OFFICE_ADDRESS=1362 Av. des Platanes, 34970 Lattes
